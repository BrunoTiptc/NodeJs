{
  "version": "0.2.0",
  "configurations": [
    {
      "type": "node",
      "request": "launch",
      "name": "Launch Arquivo Atual (limpo)",
      "skipFiles": [
        "<node_internals>/**"
      ],
      "program": "${file}",
      "console": "internalConsole",
      "internalConsoleOptions": "openOnSessionStart"
    },
    {
      "type": "node",
      "request": "launch",
      "name": "Jest Tests",
      "runtimeExecutable": "npm",
      "runtimeArgs": [
        "run",
        "test"
      ],
      "cwd": "${workspaceFolder}/Algoritmos",
      "console": "integratedTerminal",
      "internalConsoleOptions": "neverOpen"
    },
    {
      "type": "node",
      "request": "launch",
      "name": "Classificador IA (Natural)",
      "program": "${workspaceFolder}/ParadigmaDataDriven/classificador.js",
      "console": "integratedTerminal"
    }
  ]
}